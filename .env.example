# --- Configuration optionnelle ---
# L'application fonctionne entièrement SANS ces variables (voix de secours
# du navigateur). Renseignez-les pour activer la voix premium ElevenLabs et
# l'agent conversationnel.

# === Côté CLIENT (exposé au navigateur — préfixe VITE_) ===
# Identifiant de l'agent conversationnel ElevenLabs (Conversational AI) pour
# le mode « Parle avec Lumi ». L'agent-id est public/intégrable : OK ici.
VITE_ELEVENLABS_AGENT_ID=

# === Côté SERVEUR (SECRET — jamais envoyé au navigateur) ===
# Utilisé par server.js (proxy /api/tts) pour synthétiser la voix des mots
# avec EXACTEMENT la même voix que l'agent. La clé reste sur le serveur.
ELEVENLABS_API_KEY=
# L'ID de la voix ElevenLabs — METTEZ LA MÊME que celle de votre agent
# pour que la voix de l'app « colle » à celle de la conversation.
ELEVENLABS_VOICE_ID=
# (Optionnel) modèle TTS ElevenLabs. Défaut : eleven_turbo_v2_5 (il permet de
# FORCER le français — language_code=fr — pour éviter qu'un mot court comme
# « chat » soit prononcé à l'anglaise). Mettre eleven_multilingual_v2 si besoin.
ELEVENLABS_MODEL_ID=
