# --- Configuration optionnelle ---
# L'application fonctionne entièrement SANS ces clés (voix de secours du navigateur).
# Renseignez-les pour activer les voix premium et l'agent conversationnel ElevenLabs.

# Clé API ElevenLabs (text-to-speech premium). Exposée au client : utilisez une clé restreinte.
VITE_ELEVENLABS_API_KEY=

# Identifiant de la voix ElevenLabs à utiliser pour Lumi (ex. une voix française chaleureuse).
VITE_ELEVENLABS_VOICE_ID=

# Identifiant de l'agent conversationnel ElevenLabs (Conversational AI) pour le mode "Parle avec Lumi".
VITE_ELEVENLABS_AGENT_ID=
